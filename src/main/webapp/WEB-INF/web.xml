<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0" metadata-complete="false">


    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>
    <servlet>
        <servlet-name>base</servlet-name>
        <servlet-class>com.iweb.servlet.DispatcherServlet</servlet-class>
        <init-param>
            <param-name>datasourceConfiguration</param-name>
            <param-value>db.properties</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>base</servlet-name>
        <url-pattern>/login</url-pattern>
        <url-pattern>/view/*</url-pattern>
        <url-pattern>/user/*</url-pattern>
        <url-pattern>/plants/*</url-pattern>
        <url-pattern>/menu/*</url-pattern>
        <url-pattern>/department/*</url-pattern>

    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.html</url-pattern>
        <url-pattern>*.js</url-pattern>
        <url-pattern>*.css</url-pattern>
        <url-pattern>*.png</url-pattern>
        <url-pattern>*.woff</url-pattern>
        <url-pattern>*.woff2</url-pattern>
        <url-pattern>*.ttf</url-pattern>
        <url-pattern>*.svg</url-pattern>
        <url-pattern>*.eot</url-pattern>
        <url-pattern>*.gif</url-pattern>
        <url-pattern>*.json</url-pattern>
        <url-pattern>*.jpg</url-pattern>
        <url-pattern>/favicon.ico</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>session</filter-name>
        <filter-class>com.iweb.filter.SessionFilter</filter-class>
    </filter>
    <!--不经过的排除-->
    <filter-mapping>
        <filter-name>session</filter-name>
        <url-pattern>/user/*</url-pattern>
        <url-pattern>/view/*</url-pattern>
        <url-pattern>/plants/*</url-pattern>
        <url-pattern>/menu/*</url-pattern>
    </filter-mapping>


</web-app>
